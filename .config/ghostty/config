# Ghostty config — migrated from Alacritty
# Reload: Cmd+Shift+, | Docs: https://ghostty.org/docs/config

# Shell (login shell is zsh; override to fish)
command = /opt/homebrew/bin/fish

# Theme — explicit solarized dark colors for cmux compatibility
theme = Builtin Solarized Dark
background = #002b36
foreground = #839496
cursor-color = #93a1a1
cursor-text = #002b36
selection-background = #073642
selection-foreground = #93a1a1
palette = 0=#073642
palette = 1=#dc322f
palette = 2=#859900
palette = 3=#b58900
palette = 4=#268bd2
palette = 5=#d33682
palette = 6=#2aa198
palette = 7=#eee8d5
palette = 8=#002b36
palette = 9=#cb4b16
palette = 10=#586e75
palette = 11=#657b83
palette = 12=#839496
palette = 13=#6c71c4
palette = 14=#93a1a1
palette = 15=#fdf6e3

# Font
font-family = MesloLGM Nerd Font
font-size = 12

# cmux split styling (solarized dark)
unfocused-split-opacity = 0.85
unfocused-split-fill = #002b36
split-divider-color = #073642

# macOS: Option keys act as Alt/Meta (for fish & neovim)
macos-option-as-alt = true

# Restore windows/tabs/splits across restarts
window-save-state = always

# Keybinds — Cmd+Shift prefix (frees Ctrl+B for tmux)
# Splits
keybind = cmd+shift+backslash=new_split:right
keybind = cmd+shift+minus=new_split:down

# Navigate splits
keybind = cmd+shift+arrow_left=goto_split:left
keybind = cmd+shift+arrow_right=goto_split:right
keybind = cmd+shift+arrow_up=goto_split:up
keybind = cmd+shift+arrow_down=goto_split:down

# Zoom split
keybind = cmd+shift+z=toggle_split_zoom

# Equalize splits
keybind = cmd+shift+e=equalize_splits

# Close split
keybind = cmd+shift+x=close_surface

# Kill window
keybind = cmd+shift+w=close_window

# New tab
keybind = cmd+shift+c=new_tab

# Next/prev tab
keybind = cmd+shift+n=next_tab
keybind = cmd+shift+p=previous_tab

# Tab overview
keybind = cmd+shift+t=toggle_tab_overview

# Switch tab by number
keybind = cmd+shift+one=goto_tab:1
keybind = cmd+shift+two=goto_tab:2
keybind = cmd+shift+three=goto_tab:3
keybind = cmd+shift+four=goto_tab:4
keybind = cmd+shift+five=goto_tab:5
keybind = cmd+shift+six=goto_tab:6
keybind = cmd+shift+seven=goto_tab:7
keybind = cmd+shift+eight=goto_tab:8
keybind = cmd+shift+nine=goto_tab:9
